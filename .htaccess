# --- BLOK PERLINDUNGAN DARI BOT SCAN ---

# 1. Lindungi file-file sensitif dari akses web
<FilesMatch "\\.(log|lock|json|env|config)$">
    Require all denied
</FilesMatch>

# 2. Blokir bot jahat umum berdasarkan nama (User-Agent)
RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} (ahrefs|semrush|majestic|dotbot|megaindex|ltx71|neble|istellabot|seokicks|nutch|parser|spider|wordpressthemedetector|scan) [NC]
RewriteRule .* - [F,L]

# --- AKHIR BLOK PERLINDUNGAN ---


# Opsi untuk keamanan, menonaktifkan browse folder
Options -Indexes

# Mengatur tipe file .js agar dimuat sebagai modul JavaScript
AddType application/javascript .js


# --- BLOK KEAMANAN HEADER (VERSI FINAL & DIPERBARUI) ---
<IfModule mod_headers.c>
    
    # --- PERBAIKAN UNTUK PDF (MENAMBAHKAN 'blob:') ---
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.gstatic.com https://www.google.com https://apis.google.com blob:; connect-src 'self' https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://firestore.googleapis.com https://www.googleapis.com wss://*.firebasedatabase.app https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.google.com https://*.gstatic.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https://akademik.pusdikpolair.my.id https://upload.wikimedia.org https://ik.imagekit.io https://placehold.co data: blob:; frame-src 'self' https://www.google.com https://www.youtube.com blob:;"
    # --- AKHIR PERBAIKAN ---

    # Sembunyikan tanda tangan/versi software server
    Header unset Server
    Header unset X-Powered-By
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # Selalu paksa download ulang file HTML
  ExpiresByType text/html "access plus 0 seconds"

  # Cache file CSS dan JS hanya selama 1 jam
  ExpiresByType text/css "access plus 1 hour"
  ExpiresByType application/javascript "access plus 1 hour"

  # Cache gambar dan media untuk waktu yang lama
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 week"
  
  # Cache font untuk waktu yang lama
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/eot "access plus 1 year"

  # Aturan default untuk file lain (misalnya data)
  ExpiresDefault "access plus 2 days"
</IfModule>

# --- BLOK KEAMANAN HEADER (VERSI FINAL & DIPERBAIKUI) ---
<IfModule mod_headers.c>
    
    Header set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' \
            https://cdn.tailwindcss.com \
            https://cdnjs.cloudflare.com \
            https://cdn.jsdelivr.net \
            https://www.gstatic.com \
            https://www.google.com \
            https://apis.google.com \
            https://firebase.googleapis.com \
            blob:; \
        connect-src 'self' \
            https://securetoken.googleapis.com \
            https://identitytoolkit.googleapis.com \
            https://firestore.googleapis.com \
            https://firebasestorage.googleapis.com \
            https://www.googleapis.com \
            https://sistem-akademik-pusdik-polair-default-rtdb.asia-southeast1.firebasedatabase.app \
            wss://*.firebasedatabase.app \
            https://cdn.jsdelivr.net \
            https://cdnjs.cloudflare.com \
            https://www.google.com \
            https://*.gstatic.com \
            blob:; \
        style-src 'self' 'unsafe-inline' \
            https://fonts.googleapis.com \
            https://cdnjs.cloudflare.com; \
        font-src 'self' \
            https://fonts.gstatic.com \
            https://cdnjs.cloudflare.com; \
        img-src 'self' \
            https://akademik.pusdikpolair.my.id \
            https://upload.wikimedia.org \
            https://ik.imagekit.io \
            https://placehold.co \
            data: \
            blob:; \
        frame-src 'self' \
            https://www.google.com \
            https://www.youtube.com \
            https://sistem-akademik-pusdik-polair.firebaseapp.com \
            blob:;"

    # Sembunyikan tanda tangan/versi software server
    Header unset Server
    Header unset X-Powered-By
</IfModule>